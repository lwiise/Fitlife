{
  "name": "fitlife",
  "version": "2.0.0",
  "private": true,
  "description": "Fit Life 2.0 — Smart nutrition for Gulf families",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@fitlife/web",
    "dev:app": "turbo run dev --filter=@fitlife/app",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@fitlife/web",
    "build:app": "turbo run build --filter=@fitlife/app",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.9.4",
    "@types/node": "^25.9.2",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
