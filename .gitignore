# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Monorepo
.turbo/
**/.turbo/
**/node_modules/
**/.next/
**/dist/
**/.env.local
**/coverage/

# Supabase CLI workspace (auto-created at repo root by `npx supabase ...`)
# Our migrations live in apps/app/supabase/ which stays tracked.
/supabase/
