{
  "model": "opus",
  "effort": "xhigh",
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(src/**)",
      "Edit(public/**)",
      "Edit(.claude/**)",
      "Edit(CLAUDE.md)",
      "Edit(AGENTS.md)",
      "Edit(package.json)",
      "Write(src/**)",
      "Write(public/**)",
      "Write(.claude/**)",
      "Bash(npm install:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npx shadcn:*)",
      "Bash(npx aceternity-ui:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "WebFetch(domain:motion.dev)",
      "WebFetch(domain:ui.shadcn.com)",
      "WebFetch(domain:ui.aceternity.com)",
      "WebFetch(domain:magicui.design)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:code.claude.com)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Edit(.env*)",
      "Edit(node_modules/**)",
      "Write(.env*)",
      "Bash(npm publish:*)"
    ],
    "ask": [
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(npm uninstall:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "if (git status --porcelain) { git add -A; git commit -m ('auto: ' + (Get-Date -Format 'yyyy-MM-dd HH:mm:ss')); git push origin main }",
            "async": true,
            "timeout": 60,
            "statusMessage": "Auto-committing and pushing"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✓ File written. Run npm run dev if not already running.'"
          }
        ]
      }
    ]
  }
}
