{
  "extends": "@fitlife/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "netlify/functions/**/*.mts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", ".turbo"]
}
